<?xml version="1.0"?>
<sdf version="1.9">
  <model name="basic_vehicle">
    <pose>0 0 0.12 0 0 0</pose>
    <self_collide>false</self_collide>
    <static>false</static>

    <link name="base_link">
      <pose>0 0 0.08 0 0 0</pose>
      <inertial>
        <mass>8.0</mass>
        <inertia>
          <ixx>0.1200</ixx>
          <iyy>0.2867</iyy>
          <izz>0.3667</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
      <collision name="base_collision">
        <geometry>
          <box>
            <size>0.6 0.4 0.12</size>
          </box>
        </geometry>
      </collision>
      <visual name="base_visual">
        <geometry>
          <box>
            <size>0.6 0.4 0.12</size>
          </box>
        </geometry>
        <material>
          <ambient>0.15 0.2 0.65 1</ambient>
          <diffuse>0.2 0.3 0.8 1</diffuse>
        </material>
      </visual>
      <visual name="top_plate_visual">
        <pose>0 0 0.09 0 0 0</pose>
        <geometry>
          <box>
            <size>0.34 0.24 0.03</size>
          </box>
        </geometry>
        <material>
          <ambient>0.85 0.85 0.9 1</ambient>
          <diffuse>0.9 0.9 0.95 1</diffuse>
        </material>
      </visual>
    </link>

    <link name="front_left_wheel">
      <pose>0.18 0.22 0.08 1.57079632679 0 0</pose>
      <inertial>
        <mass>1.0</mass>
        <inertia>
          <ixx>0.00335</ixx>
          <iyy>0.00180</iyy>
          <izz>0.00180</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
      <collision name="front_left_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.1</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.5</mu>
              <mu2>1.5</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="front_left_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.1</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.12 0.12 0.12 1</diffuse>
        </material>
      </visual>
    </link>

    <link name="rear_left_wheel">
      <pose>-0.18 0.22 0.08 1.57079632679 0 0</pose>
      <inertial>
        <mass>1.0</mass>
        <inertia>
          <ixx>0.00335</ixx>
          <iyy>0.00180</iyy>
          <izz>0.00180</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
      <collision name="rear_left_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.1</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.5</mu>
              <mu2>1.5</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="rear_left_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.1</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.12 0.12 0.12 1</diffuse>
        </material>
      </visual>
    </link>

    <link name="front_right_wheel">
      <pose>0.18 -0.22 0.08 1.57079632679 0 0</pose>
      <inertial>
        <mass>1.0</mass>
        <inertia>
          <ixx>0.00335</ixx>
          <iyy>0.00180</iyy>
          <izz>0.00180</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
      <collision name="front_right_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.1</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.5</mu>
              <mu2>1.5</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="front_right_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.1</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.12 0.12 0.12 1</diffuse>
        </material>
      </visual>
    </link>

    <link name="rear_right_wheel">
      <pose>-0.18 -0.22 0.08 1.57079632679 0 0</pose>
      <inertial>
        <mass>1.0</mass>
        <inertia>
          <ixx>0.00335</ixx>
          <iyy>0.00180</iyy>
          <izz>0.00180</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
      <collision name="rear_right_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.1</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.5</mu>
              <mu2>1.5</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="rear_right_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.1</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.12 0.12 0.12 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="front_left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>front_left_wheel</child>
      <pose relative_to="base_link">0.18 0.22 0 0 0 0</pose>
      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>
        <limit>
          <lower>-1000000</lower>
          <upper>1000000</upper>
          <effort>40</effort>
          <velocity>30</velocity>
        </limit>
        <dynamics>
          <damping>0.2</damping>
          <friction>0.0</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="rear_left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>rear_left_wheel</child>
      <pose relative_to="base_link">-0.18 0.22 0 0 0 0</pose>
      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>
        <limit>
          <lower>-1000000</lower>
          <upper>1000000</upper>
          <effort>40</effort>
          <velocity>30</velocity>
        </limit>
        <dynamics>
          <damping>0.2</damping>
          <friction>0.0</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="front_right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>front_right_wheel</child>
      <pose relative_to="base_link">0.18 -0.22 0 0 0 0</pose>
      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>
        <limit>
          <lower>-1000000</lower>
          <upper>1000000</upper>
          <effort>40</effort>
          <velocity>30</velocity>
        </limit>
        <dynamics>
          <damping>0.2</damping>
          <friction>0.0</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="rear_right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>rear_right_wheel</child>
      <pose relative_to="base_link">-0.18 -0.22 0 0 0 0</pose>
      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>
        <limit>
          <lower>-1000000</lower>
          <upper>1000000</upper>
          <effort>40</effort>
          <velocity>30</velocity>
        </limit>
        <dynamics>
          <damping>0.2</damping>
          <friction>0.0</friction>
        </dynamics>
      </axis>
    </joint>

    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>front_left_wheel_joint</left_joint>
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>front_right_wheel_joint</right_joint>
      <right_joint>rear_right_wheel_joint</right_joint>
      <wheel_separation>0.44</wheel_separation>
      <wheel_radius>0.10</wheel_radius>
      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <odom_publish_frequency>30</odom_publish_frequency>
      <max_linear_acceleration>2.0</max_linear_acceleration>
      <max_angular_acceleration>3.0</max_angular_acceleration>
      <max_linear_velocity>1.5</max_linear_velocity>
      <max_angular_velocity>2.5</max_angular_velocity>
    </plugin>

    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <topic>/world/basic_vehicle_world/model/basic_vehicle/joint_state</topic>
    </plugin>
  </model>
</sdf>
